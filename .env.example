# Copy this file to .env and replace the placeholder values with real ones.
# The .env file is gitignored and must never be committed.
#
# HF_TOKEN should be a Hugging Face user access token with the permissions
# documented in oncall_env/README.md.

HF_TOKEN=replace-with-your-huggingface-token
API_BASE_URL=https://router.huggingface.co/v1
MODEL_NAME=Qwen/Qwen2.5-72B-Instruct

# Optional: default task for local server runs.
ONCALL_TASK=memory_leak
